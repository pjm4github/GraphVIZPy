<?xml version="1.0" encoding="UTF-8"?>
<gxl xmlns:xlink="http://www.w3.org/1999/xlink">
  <graph id="UndirectedSample" edgemode="undirected">
    <node id="A">
      <attr name="label"><string>Alpha</string></attr>
    </node>
    <node id="B">
      <attr name="label"><string>Beta</string></attr>
    </node>
    <node id="C">
      <attr name="label"><string>Gamma</string></attr>
    </node>
    <edge from="A" to="B">
      <attr name="weight"><int>3</int></attr>
    </edge>
    <edge from="B" to="C">
      <attr name="weight"><int>2</int></attr>
    </edge>
    <edge from="A" to="C">
      <attr name="weight"><int>5</int></attr>
    </edge>
  </graph>
</gxl>
