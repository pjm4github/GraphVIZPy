// Comprehensive test fixture for HTML-table label support (Phase 4a).
//
// Exercises the TABLE / TR / TD vocabulary currently supported by
// ``gvpy.grammar.html_label``:
//
//   TABLE attributes : BORDER, CELLBORDER, CELLPADDING, CELLSPACING,
//                      BGCOLOR, COLOR, ALIGN, VALIGN, HREF
//   TR attributes    : (none used here — TR is a pure container)
//   TD attributes    : ALIGN, VALIGN, BGCOLOR, COLOR, BORDER,
//                      CELLPADDING, COLSPAN, ROWSPAN, HREF
//
// Cell content combines plain text, FONT/B/I/U styling, BR line
// breaks, and a nested table.  COLSPAN / ROWSPAN are parsed onto the
// cell but not yet honoured in layout — the tests check that the
// attribute makes it to the AST even where rendering ignores it.
digraph html_tables {
    rankdir=LR;
    fontname="Times-Roman";
    fontsize=14;
    node [shape=plaintext, fontname="Times-Roman"];

    // ── Minimal 2×2 table ────────────────────────────────────────────
    t_simple [label=<
        <TABLE>
            <TR><TD>A</TD><TD>B</TD></TR>
            <TR><TD>C</TD><TD>D</TD></TR>
        </TABLE>
    >];

    // ── Header row with BGCOLOR ──────────────────────────────────────
    t_header [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD BGCOLOR="#d0d0d0"><B>Name</B></TD>
                <TD BGCOLOR="#d0d0d0"><B>Value</B></TD></TR>
            <TR><TD>alpha</TD><TD>1</TD></TR>
            <TR><TD>beta</TD><TD>2</TD></TR>
            <TR><TD>gamma</TD><TD>3</TD></TR>
        </TABLE>
    >];

    // ── Cell alignment (ALIGN + VALIGN) ──────────────────────────────
    t_align [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLPADDING="6" CELLSPACING="0">
            <TR>
                <TD ALIGN="LEFT" VALIGN="TOP">LT</TD>
                <TD ALIGN="CENTER" VALIGN="TOP">CT</TD>
                <TD ALIGN="RIGHT" VALIGN="TOP">RT</TD>
            </TR>
            <TR>
                <TD ALIGN="LEFT" VALIGN="MIDDLE">LM</TD>
                <TD ALIGN="CENTER" VALIGN="MIDDLE">CM</TD>
                <TD ALIGN="RIGHT" VALIGN="MIDDLE">RM</TD>
            </TR>
            <TR>
                <TD ALIGN="LEFT" VALIGN="BOTTOM">LB</TD>
                <TD ALIGN="CENTER" VALIGN="BOTTOM">CB</TD>
                <TD ALIGN="RIGHT" VALIGN="BOTTOM">RB</TD>
            </TR>
        </TABLE>
    >];

    // ── Styled cell contents (FONT / B / I / BR) ─────────────────────
    t_styled [label=<
        <TABLE BORDER="2" CELLBORDER="1" CELLPADDING="8" CELLSPACING="2"
               BGCOLOR="#f0f0f0" COLOR="#1e40af">
            <TR>
                <TD><FONT POINT-SIZE="18" COLOR="#1e40af"><B>Title</B></FONT></TD>
                <TD><FONT POINT-SIZE="10"><I>subtitle</I></FONT></TD>
            </TR>
            <TR>
                <TD>line 1<BR/>line 2</TD>
                <TD>E = mc<SUP>2</SUP></TD>
            </TR>
        </TABLE>
    >];

    // ── Attribute-only table: BORDER=0 ────────────────────────────────
    t_borderless [label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4" CELLSPACING="0">
            <TR><TD>key:</TD><TD>value</TD></TR>
            <TR><TD>foo:</TD><TD>bar</TD></TR>
        </TABLE>
    >];

    // ── Nested table inside a cell ───────────────────────────────────
    t_nested [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD>outer-left</TD>
                <TD>
                    <TABLE BORDER="0" CELLBORDER="1" CELLPADDING="3" CELLSPACING="0">
                        <TR><TD>in-a</TD><TD>in-b</TD></TR>
                        <TR><TD>in-c</TD><TD>in-d</TD></TR>
                    </TABLE>
                </TD></TR>
            <TR><TD COLSPAN="2">spans both (parsed only)</TD></TR>
        </TABLE>
    >];

    // ── Edge label as a table ────────────────────────────────────────
    t_simple -> t_header [label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="2" CELLSPACING="0"
               BGCOLOR="#ffffcc">
            <TR><TD><B>edge</B></TD></TR>
            <TR><TD><FONT POINT-SIZE="10">label</FONT></TD></TR>
        </TABLE>
    >];

    // Chain the rest so the graph stays connected for layout.
    t_header -> t_align;
    t_align -> t_styled;
    t_styled -> t_borderless;
    t_borderless -> t_nested;
}
