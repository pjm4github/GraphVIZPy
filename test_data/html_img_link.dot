// Test fixture for HTML-label IMG + hyperlink attributes.
//
// Items covered: #3 (IMG SRC / SCALE modes) and #4 (HREF / TARGET
// / TITLE / TOOLTIP / ID on TABLE and TD).
//
// The test image is a 40×40 solid-blue PNG generated by the test
// setup at ``test_img.png``.  When that file is missing
// the probe falls back to a 50×50 default — the fixture still
// renders but loses the pixel-accurate assertions.
digraph html_img_link {
    rankdir=LR;
    fontname="Times-Roman";
    fontsize=14;
    // ``imagepath`` tells both ``dot.exe`` and our Python renderer
    // where to find IMG SRC files.  Listing ``.`` first + ``test_data``
    // makes the fixture resolve the image regardless of whether the
    // command is run from the repo root (SRC found in test_data/) or
    // from inside test_data/ (SRC found in ./).  ``;`` separator is
    // the Windows convention; ``:`` also works on Unix.
    imagepath="test_data;.";
    node [shape=plaintext, fontname="Times-Roman"];

    // ── Plain IMG with default SCALE="FALSE" (natural size) ──────────
    t_img_plain [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
            <TR><TD><IMG SRC="test_img.png"/></TD></TR>
        </TABLE>
    >];

    // ── SCALE="TRUE" inside a larger (WIDTH/HEIGHT) cell ─────────────
    // Graphviz's C HTML parser is strict: a cell containing an IMG
    // must have no surrounding whitespace, since whitespace between
    // tags counts as text content and a TD can't mix text + IMG.
    // Keep the <IMG/> flush against <TD …> and </TD>.
    t_img_scale_true [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
            <TR><TD WIDTH="80" HEIGHT="80" FIXEDSIZE="TRUE"><IMG SRC="test_img.png" SCALE="TRUE"/></TD></TR>
        </TABLE>
    >];

    // ── SCALE="BOTH" stretches (no aspect ratio preservation) ───────
    t_img_scale_both [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
            <TR><TD WIDTH="100" HEIGHT="30" FIXEDSIZE="TRUE"><IMG SRC="test_img.png" SCALE="BOTH"/></TD></TR>
        </TABLE>
    >];

    // ── SCALE="WIDTH" fills width; SCALE="HEIGHT" fills height ──────
    t_img_scale_axes [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
            <TR><TD WIDTH="80" HEIGHT="40" FIXEDSIZE="TRUE"><IMG SRC="test_img.png" SCALE="WIDTH"/></TD><TD WIDTH="40" HEIGHT="80" FIXEDSIZE="TRUE"><IMG SRC="test_img.png" SCALE="HEIGHT"/></TD></TR>
        </TABLE>
    >];

    // ── HREF + TARGET + TITLE on TABLE (outer link) ──────────────────
    t_href_table [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"
               HREF="https://claude.ai" TARGET="_blank"
               TITLE="Open Claude">
            <TR><TD>visit Claude</TD></TR>
        </TABLE>
    >];

    // ── HREF on an individual TD ─────────────────────────────────────
    t_href_cell [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR>
                <TD HREF="https://claude.ai" TARGET="_blank"
                    TITLE="cell link">link-cell</TD>
                <TD>plain</TD>
            </TR>
        </TABLE>
    >];

    // ── TOOLTIP alias (same effect as TITLE) ─────────────────────────
    t_tooltip_cell [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR>
                <TD TOOLTIP="hover me">no href</TD>
            </TR>
        </TABLE>
    >];

    // ── ID wiring on TD (propagates to outer <g id="…">) ────────────
    t_id_cell [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR>
                <TD ID="cellOne">first</TD>
                <TD ID="cellTwo">second</TD>
            </TR>
        </TABLE>
    >];

    // ── Combined: image cell with HREF to Claude ─────────────────────
    t_img_link [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
            <TR><TD HREF="https://claude.ai" TARGET="_blank" TITLE="Claude"><IMG SRC="test_img.png" SCALE="TRUE"/></TD></TR>
        </TABLE>
    >];

    // Chain for layout connectivity.
    t_img_plain -> t_img_scale_true;
    t_img_scale_true -> t_img_scale_both;
    t_img_scale_both -> t_img_scale_axes;
    t_img_scale_axes -> t_href_table;
    t_href_table -> t_href_cell;
    t_href_cell -> t_tooltip_cell;
    t_tooltip_cell -> t_id_cell;
    t_id_cell -> t_img_link;
}
