// D5 cluster-straddle regression fixture.
//
// Each subgraph ``case_<X>_...`` tests one specific failure mode that
// the TODO В§1 D5 investigation identified on the audit corpus.  The
// whole graph is kept small (в‰€ 20 nodes / 4 clusters) so the rendered
// output can be inspected manually, and so Python-vs-C differences
// show up immediately rather than being buried in a 200-node scene.
//
// Expected counts (measured 2026-04-22):
//
//   C-side (``dot.exe -Tsvg``):
//     visible cluster crossings : 0
//     D5 mincross-level         : 0
//
//   Python (``PYTHONHASHSEED=0`` for determinism), after the
//   2026-04-22 run_mincross backend swap (cluster_medians +
//   cluster_reorder + cluster_transpose in place of
//   order_by_weighted_median + transpose_rank):
//     visible cluster crossings : 1
//     D5 mincross-level         : 2
//
//   Previous baseline (legacy run_mincross backend, before the
//   swap): visible cluster crossings = 4.
//
// The regression gate in ``tests/test_d5_regression.py`` fixes
// ``PYTHONHASHSEED=0`` and asserts visible crossings в‰¤ 1.  Any
// future D5 fix that reduces this further should tighten the
// constant in that file.  A regression that raises it fails the
// test and points at the specific scenario.
//
// Hand-built May 2026; the case-level comments inside each subgraph
// explain what's being exercised.
digraph d5_regression {
    rankdir=TB;
    compound=true;
    fontname="Times-Roman";
    node [shape=box, fontname="Times-Roman"];

    // Root connector вЂ” each test subgraph wires into this so the
    // whole fixture is one connected component.  Carries no
    // cluster-straddle semantics itself.
    root [label="root"];

    // в”Ђв”Ђ Case A: adjacent-rank RL-flip в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Two sibling clusters (A_left and A_right) sit on rank 2.  An
    // external node ``A_in`` on rank 1 has edges into members of
    // both clusters; an external node ``A_out`` on rank 3 collects
    // edges from both.  If mincross places A_in on one side of the
    // cluster pair and A_out on the opposite side, the collector
    // edges cross through both clusters (the 2796-class RL pattern).
    subgraph cluster_A_left {
        label="A_left";
        color="#d0d0d0";
        A_l1; A_l2;
    }
    subgraph cluster_A_right {
        label="A_right";
        color="#d0d0d0";
        A_r1; A_r2;
    }
    A_in  [label="A_in"];
    A_out [label="A_out"];
    root -> A_in;
    A_in  -> A_l1;
    A_in  -> A_r1;
    A_l2  -> A_out;
    A_r2  -> A_out;

    // в”Ђв”Ђ Case B: thread-through в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // ``B_out`` is a non-cluster node on the same rank as
    // cluster_B's members.  Correct mincross keeps B_out strictly
    // left or right of cluster_B's order range.  Thread-through
    // (2239-class) would land B_out between cluster members.
    subgraph cluster_B {
        label="cluster_B";
        color="#eff6ff";
        B_1; B_2; B_3;
    }
    B_in  [label="B_in"];
    B_out [label="B_out"];
    B_sink [label="B_sink"];
    root  -> B_in;
    B_in  -> B_1;
    B_in  -> B_out;
    B_3   -> B_sink;
    B_out -> B_sink;

    // в”Ђв”Ђ Case C: multi-rank edge threads cluster в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // ``C_src`` on rank 1 connects to ``C_dst`` on rank 4 via a
    // 3-rank virtual chain.  cluster_C has members on ranks 2 and 3.
    // If mincross places the virtual chain on the opposite side of
    // cluster_C from its endpoints, the edge crosses the cluster at
    // both intermediate ranks (aa1332 ``c0->c5359`` class).
    subgraph cluster_C {
        label="cluster_C";
        color="#fef3c7";
        C_m1; C_m2;
    }
    C_src [label="C_src"];
    C_dst [label="C_dst"];
    C_side [label="C_side"];
    root   -> C_src;
    C_src  -> C_dst;
    C_side -> C_m1;
    C_m1   -> C_m2;
    C_m2   -> C_dst;

    // в”Ђв”Ђ Case D: nested-cluster interclrep в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // ``cluster_D_outer`` contains ``cluster_D_inner``.  A node
    // outside the outer cluster (D_ext) has an edge to a node inside
    // the INNER cluster (D_i1).  This exercises C's
    // ``class2.c: interclrep`` + ``make_chain`` вЂ” Python creates
    // ``_icv_*`` chain virtuals that have to land on the
    // same side as D_ext to avoid crossing cluster_D_outer.
    subgraph cluster_D_outer {
        label="D_outer";
        color="#dcfce7";
        D_o1; D_o2;
        subgraph cluster_D_inner {
            label="D_inner";
            color="#bae6fd";
            D_i1; D_i2;
        }
    }
    D_ext [label="D_ext"];
    root  -> D_ext;
    D_ext -> D_i1;
    D_o1  -> D_i2;
    D_i2  -> D_o2;

    // Chain the cases in a visible grid so the layout is easy to eyeball.
    // Forces the four sub-graphs to lay out top-to-bottom in order.
    root -> A_in [style=invis];
    A_in -> B_in [style=invis];
    B_in -> C_src [style=invis];
    C_src -> D_ext [style=invis];
}
