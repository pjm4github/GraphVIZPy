// Sfdp scalable force-directed layout demo — social network clusters
// Usage: python gvcli.py -Ksfdp test_data/sfdp_demo.gv -Tsvg -o sfdp_demo.svg
//
// 60 nodes, 90 edges — large enough for multilevel coarsening
// and Barnes-Hut quadtree to activate.
graph social {
    // Group A: engineering team (dense cluster)
    a1 -- a2; a1 -- a3; a1 -- a4; a1 -- a5;
    a2 -- a3; a2 -- a4; a2 -- a6; a2 -- a7;
    a3 -- a5; a3 -- a8; a4 -- a6; a4 -- a9;
    a5 -- a7; a5 -- a10; a6 -- a8; a7 -- a9;
    a8 -- a10; a9 -- a10; a6 -- a7; a3 -- a4;

    // Group B: marketing team
    b1 -- b2; b1 -- b3; b1 -- b4; b1 -- b5;
    b2 -- b3; b2 -- b6; b3 -- b7; b4 -- b8;
    b5 -- b6; b5 -- b7; b6 -- b8; b7 -- b8;
    b3 -- b5; b4 -- b6; b2 -- b4;

    // Group C: sales team
    c1 -- c2; c1 -- c3; c1 -- c4; c1 -- c5;
    c2 -- c3; c2 -- c6; c3 -- c7; c4 -- c8;
    c5 -- c6; c5 -- c9; c6 -- c10; c7 -- c8;
    c8 -- c9; c9 -- c10; c3 -- c5; c4 -- c7;

    // Group D: support team
    d1 -- d2; d1 -- d3; d1 -- d4; d2 -- d5;
    d3 -- d6; d4 -- d7; d5 -- d8; d6 -- d9;
    d7 -- d10; d8 -- d9; d9 -- d10; d2 -- d3;
    d4 -- d5; d6 -- d7; d8 -- d10;

    // Group E: exec team (small hub)
    e1 -- e2; e1 -- e3; e1 -- e4; e1 -- e5;
    e2 -- e3; e3 -- e4; e4 -- e5; e2 -- e5;

    // Group F: contractors
    f1 -- f2; f1 -- f3; f1 -- f4; f1 -- f5;
    f2 -- f3; f3 -- f4; f4 -- f5; f5 -- f2;

    // Inter-group bridges (sparse connections)
    a1 -- b1; a3 -- c2; a7 -- d1;
    b4 -- c1; b6 -- e1; c5 -- d3;
    d1 -- e2; e3 -- f1; a10 -- f3;
    b8 -- d7; c10 -- e4; f5 -- a5;
}
