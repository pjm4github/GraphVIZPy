digraph CrashPOC {
  concentrate=true

  
  subgraph cluster_outer { 
    subgraph cluster_inner {  
      A -> B -> C -> D
      B -> E
      I -> H -> C -> F 
      D -> G

      P [shape=point style=invis]
      {B C D E F} -> P [constraint="false" style=invis]
    }

    H -> A
    {rank=same; H; B}
  }
}

