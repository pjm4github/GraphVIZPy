<?xml version="1.0" encoding="UTF-8"?>
<gxl xmlns:xlink="http://www.w3.org/1999/xlink">
  <graph id="Graph1" edgemode="directed">
    <node id="x"/>
    <node id="y"/>
    <edge from="x" to="y"/>
  </graph>
  <graph id="Graph2" edgemode="undirected">
    <node id="p"/>
    <node id="q"/>
    <edge from="p" to="q"/>
  </graph>
</gxl>
